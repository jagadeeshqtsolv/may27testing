{
  "id": "verify-cart-and-update-remove",
  "testPlanId": "d378037a-5263-45b0-b944-9edc2246446a",
  "requirementId": "7ec70db9-0535-4c01-9d3f-a829ed974fde",
  "suiteName": "Product Search & Add to Cart - Functional",
  "case": {
    "id": "verify-cart-and-update-remove",
    "title": "User can view cart, verify product, update quantity, and remove product",
    "priority": "P1",
    "platforms": [
      "chrome",
      "firefox",
      "safari",
      "edge"
    ],
    "preconditions": [],
    "steps": [
      {
        "id": "step1",
        "action": "openUrl",
        "targetDescription": "Navigate to Amazon India homepage",
        "value": "https://www.amazon.in/"
      },
      {
        "id": "step2",
        "action": "fill",
        "targetDescription": "Enter product name in search bar",
        "locatorHint": "id=twotabsearchtextbox",
        "value": "samsung s26 ultra"
      },
      {
        "id": "step3",
        "action": "tap",
        "targetDescription": "Click search button",
        "locatorHint": "id=nav-search-submit-button"
      },
      {
        "id": "step4",
        "action": "tap",
        "targetDescription": "Click first product in search results",
        "locatorHint": "data-component-type=s-search-result"
      },
      {
        "id": "step5",
        "action": "tap",
        "targetDescription": "Click Add to Cart button",
        "locatorHint": "id=add-to-cart-button"
      },
      {
        "id": "step6",
        "action": "tap",
        "targetDescription": "Click cart icon to go to cart page",
        "locatorHint": "id=nav-cart"
      },
      {
        "id": "step7",
        "action": "assertContainsText",
        "targetDescription": "Cart contains the selected product",
        "locatorHint": "sc-product-title",
        "assertion": "samsung s26 ultra"
      },
      {
        "id": "step8",
        "action": "selectOption",
        "targetDescription": "Update quantity to 2",
        "locatorHint": "name=quantity",
        "value": "2"
      },
      {
        "id": "step9",
        "action": "assertValue",
        "targetDescription": "Quantity is updated to 2",
        "locatorHint": "name=quantity",
        "assertion": "2"
      },
      {
        "id": "step10",
        "action": "tap",
        "targetDescription": "Remove product from cart",
        "locatorHint": "value=Delete"
      },
      {
        "id": "step11",
        "action": "assertHidden",
        "targetDescription": "Product is removed from cart",
        "locatorHint": "sc-product-title"
      }
    ],
    "tags": [
      "@functional",
      "@regression"
    ]
  }
}
